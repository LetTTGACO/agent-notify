# AgentNotify configuration.
# Copy this file to `.env` and edit. Every variable below is listed with its
# default. Required variables have no default and must be set.

# ── Required ────────────────────────────────────────────────────────────────
# Authentication tokens agents use to post hook events.
# Comma-separated list of `name:token` pairs, e.g. macbook:abc123,server:xyz789.
# At least one entry is required.
AGENT_NOTIFY_TOKENS=macbook:dev-token-change-me

# Push provider: "bark" or "ntfy". Default: bark
AGENT_NOTIFY_PROVIDER=bark

# Bark endpoint (required when AGENT_NOTIFY_PROVIDER=bark).
# Full URL including your device key, e.g. https://api.day.app/your-device-key
BARK_ENDPOINT=https://api.day.app/example-device-key

# ntfy endpoint (required when AGENT_NOTIFY_PROVIDER=ntfy).
# Base URL of your ntfy server + topic, e.g. https://ntfy.example.com/my-topic
NTFY_ENDPOINT=

# Optional access token for a protected ntfy topic. Leave blank for public topics.
NTFY_TOKEN=

# ── Server ───────────────────────────────────────────────────────────────────
# Bind address and port the HTTP server listens on. Defaults: 0.0.0.0 / 8787
AGENT_NOTIFY_HOST=0.0.0.0
AGENT_NOTIFY_PORT=8787

# ── Notification behavior ────────────────────────────────────────────────────
# Notification language: "en" or "zh". Default: en
AGENT_NOTIFY_LANGUAGE=en

# Suppress consecutive permission/question notifications within this window (seconds).
# Set to 0 to disable. Default: 60
AGENT_NOTIFY_COOLDOWN_SECONDS=60

# Only notify on completion for an agent session if it ran at least this many
# seconds — filters out quick turnarounds. Set to 0 to notify on every
# completion. Defaults: 120
AGENT_NOTIFY_CLAUDE_COMPLETION_MIN_SECONDS=120
AGENT_NOTIFY_CODEX_COMPLETION_MIN_SECONDS=120
AGENT_NOTIFY_OPENCODE_COMPLETION_MIN_SECONDS=120

# ── Logging ──────────────────────────────────────────────────────────────────
# Path to the JSONL event log. Default: ./data/events.jsonl
AGENT_NOTIFY_LOG_PATH=./data/events.jsonl

# Log full raw hook payloads alongside the safe summary. Default: false
AGENT_NOTIFY_LOG_RAW=false
